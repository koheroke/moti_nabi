// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {
  id               String   @id @default(cuid())
  email            String   @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  memberships      SiteMember[]
  accounts  Account[]
  profile   UserProfile?
  auth      UserAuth?
  @@map("users")
}



model UserProfile {
   id              String  @id @default(cuid())
   userId          String  @unique
   iconUrl          String?
   name             String
   snsAccounts      Json 
   followUserIds    String[]
   bookmarkWorkIds  String[]
   bio              String?
   user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
   @@map("user_profiles")
}



model UserAuth {
  id              String  @id @default(cuid())
  userId          String  @unique
  twoFactorSecret  String?
  secoundfaEnabled       Boolean @default(false)
  passwordHash     String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@map("user_auths")
}
model Account {
  id                  String @id @default(cuid())
  userId              String
  provider            String
  providerAccountId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([provider, providerAccountId])
}

model SiteMember {
  id        String   @id @default(cuid())
  workId    String
  userId    String
  role      SiteRole
  addedAt   DateTime                                            @default(now())
  work      Work     @relation(fields: [workId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([workId, userId])
  @@map("site_members")
}
enum SiteRole {
  owner
  editor
  viewer
}

model Work {
  id            String   @id @default(cuid())
  createdAt    DateTime @default(now())
  name          String
  bio           String
  thumbnailUrl  String
  data          String
  public        Boolean
  likes         Int      @default(0)
  tags          String[]
  copies        Int      @default(0)
  members       SiteMember[]
  @@map("works")
}

